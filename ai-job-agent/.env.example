LOG_LEVEL=INFO
HEADLESS=true

# HTTP API (api_server.py)
# API_HOST=127.0.0.1
# API_PORT=8000

# Auth (JWT). Change JWT_SECRET in any shared/production deploy.
# JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRE_HOURS=168

# OpenAI — smart CV analysis (optional)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Token limits for AI matching (optional)
OPENAI_CV_SUMMARY_MAX_CHARS=3500
OPENAI_JOB_MAX_CHARS=4000
OPENAI_MAX_COLLECTION_ROLES=4

# Auto-apply — sending your CV through Drushim
# APPLY_HEADLESS=false shows the browser while applying (recommended).
APPLY_HEADLESS=false
# AUTO_SUBMIT=false fills the form but does not click the final "send" button.
AUTO_SUBMIT=true
# AUTO_GENERATE_COVER_LETTER=true generates a cover letter from saved CV data when none is saved.
AUTO_GENERATE_COVER_LETTER=false
# Optional Drushim login. Required for automated apply on Drushim.
DRUSHIM_EMAIL=
DRUSHIM_PASSWORD=

# Job collection depth (optional). Web UI (AGENT_CV_ID) defaults are higher than before.
# COLLECT_MAX_QUERIES=5
# COLLECT_MAX_CATEGORIES=3
# DRUSHIM_MAX_PAGES=4
# LINKEDIN_LOCATION=Israel
# LINKEDIN_GEO_ID=101620260
# LINKEDIN_JOBS_PER_PAGE=10
# LINKEDIN_MAX_PAGES=5
# LINKEDIN_MAX_RETRIES=3
# GOTFRIENDS_MAX_PAGES=3

# LinkedIn login — required for Easy Apply jobs on LinkedIn.
# Set these in Render → Environment (or .env locally) for one-click apply.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
